#!/usr/bin/env bash
# cac-setup — Zero-interaction CAC reader + certificate setup for Niello
#
# Run on first login via niello-init. No interaction required.
# Handles: pcscd, OpenSC module registration, NSS dbs, GnuPG CCID disable.
#
# To force re-run: rm ~/.local/share/niello/.cac-setup-done

set -eo pipefail

OPENSCLIB=$(find /usr/lib64 -name "opensc-pkcs11.so" 2>/dev/null | head -1)
P11PROXY="/usr/lib64/pkcs11/p11-kit-proxy.so"

log()  { echo "➜  CAC: $1"; }
ok()   { echo "✔  CAC: $1"; }
warn() { echo "!  CAC: $1"; }

# ── Pre-flight: ensure user is in pcscd group ────────────────────────────────
if ! groups "$USER" 2>/dev/null | grep -qw pcscd; then
    sudo usermod -aG pcscd "$USER" 2>/dev/null \
        && log "added $USER to pcscd group (re-login required for group take effect)" \
        || warn "could not add $USER to pcscd group"
fi

# ── pcscd — enable socket (hotplug-aware) + service ────────────────────────
log "enabling pcscd..."
systemctl enable --now pcscd.socket 2>/dev/null \
    && ok "pcscd.socket enabled" \
    || { systemctl enable --now pcscd 2>/dev/null \
         && ok "pcscd.service enabled"; }
sleep 2

# ── GnuPG scdaemon — disable CCID so gpg doesn't steal the card from pcscd ─
SCDAEMON_CONF="$HOME/.gnupg/scdaemon.conf"
mkdir -p "$HOME/.gnupg" && chmod 700 "$HOME/.gnupg"
if [[ -f "$SCDAEMON_CONF" ]] && grep -q "disable-ccid" "$SCDAEMON_CONF" 2>/dev/null; then
    ok "scdaemon: CCID already disabled"
else
    printf 'disable-ccid\n' >> "$SCDAEMON_CONF"
    gpgconf --kill scdaemon 2>/dev/null || true
    ok "scdaemon: CCID disabled (avoids conflict with pcscd)"
fi

# ── p11-kit system module (already in /etc/pkcs11/modules from Containerfile) ─
if [[ -f /etc/pkcs11/modules/opensc.module ]]; then
    ok "p11-kit: OpenSC module present"
else
    log "p11-kit: registering OpenSC module..."
    if [[ -n "$OPENSCLIB" ]]; then
        sudo tee /etc/pkcs11/modules/opensc.module > /dev/null << PKCS11CONF
module: $OPENSCLIB
critical: no
PKCS11CONF
        ok "p11-kit: OpenSC registered"
    fi
fi

# ── NSS user db (shared by Chromium/Electron/Firefox) ────────────────────────
NSSDB="$HOME/.pki/nssdb"
mkdir -p "$NSSDB"
if [[ ! -f "$NSSDB/cert9.db" ]]; then
    certutil -d sql:"$NSSDB" -N --empty-password 2>/dev/null \
        && ok "NSS db created" \
        || warn "certutil failed — NSS db skipped"
fi

if [[ -n "$OPENSCLIB" ]] && [[ -f "$NSSDB/cert9.db" ]]; then
    if modutil -dbdir sql:"$NSSDB" -list 2>/dev/null | grep -q "OpenSC"; then
        ok "NSS: OpenSC already registered"
    else
        modutil -dbdir sql:"$NSSDB" -add "OpenSC" \
            -libfile "$OPENSCLIB" -mechanisms FRIENDLY 2>/dev/null \
            && ok "NSS: OpenSC registered" \
            || warn "NSS: modutil failed"
    fi
fi

# ── Firefox profiles ──────────────────────────────────────────────────────────
log "configuring Firefox PKCS#11..."
for profile in "$HOME"/.mozilla/firefox/*.default*; do
    [[ -d "$profile" ]] || continue
    if modutil -dbdir sql:"$profile" -list 2>/dev/null | grep -q "OpenSC"; then
        ok "Firefox: $(basename "$profile") — OpenSC present"
        continue
    fi
    if command -v modutil &>/dev/null; then
        modutil -dbdir sql:"$profile" -create -force 2>/dev/null || true
        modutil -dbdir sql:"$profile" \
            -add "OpenSC" -libfile "$OPENSCLIB" \
            -mechanisms FRIENDLY -force 2>/dev/null \
            && ok "Firefox: $(basename "$profile") — PKCS#11 configured" \
            || warn "Firefox: modutil failed for $(basename "$profile")"
    fi
done

# Flatpak Firefox uses its own sandboxed NSS — register module inside the sandbox
if command -v flatpak &>/dev/null; then
    FLATPAK_FIREFOX_ID=$(flatpak list --app 2>/dev/null | grep -i firefox | awk '{print $1}' | head -1)
    if [[ -n "$FLATPAK_FIREFOX_ID" ]]; then
        log "configuring Flatpak Firefox..."
        flatpak run --command=bash "$FLATPAK_FIREFOX_ID" -c \
            'if [ ! -d "$HOME/.pki/nssdb" ]; then mkdir -p "$HOME/.pki/nssdb"; certutil -d sql:"$HOME/.pki/nssdb" -N --empty-password 2>/dev/null; fi
             OPENSC_LIB=$(find /usr/lib -name "opensc-pkcs11.so" 2>/dev/null | head -1)
             if [ -n "$OPENSC_LIB" ]; then
               modutil -dbdir sql:"$HOME/.pki/nssdb" -add "OpenSC" -libfile "$OPENSC_LIB" -mechanisms FRIENDLY 2>/dev/null \
                 && echo "Flatpak Firefox: OpenSC registered" || echo "Flatpak Firefox: modutil failed"
             fi' 2>/dev/null \
            && ok "Flatpak Firefox: PKCS#11 configured" \
            || warn "Flatpak Firefox: PKCS#11 setup failed"
    fi
fi

# ── Okular PDF signing (KDE) ─────────────────────────────────────────────────
OKULAR_PKCS11_LIB="${OPENSCLIB:-/usr/lib64/pkcs11/opensc-pkcs11.so}"
KDE_GLOBALS="$HOME/.config/kdeglobals"
mkdir -p "$(dirname "$KDE_GLOBALS")"
if [[ -f "$KDE_GLOBALS" ]] && grep -q "pkcs11" "$KDE_GLOBALS" 2>/dev/null; then
    ok "Okular: kdeglobals already has PKCS#11"
else
    cat >> "$KDE_GLOBALS" 2>/dev/null << KDEPKCS11

[Crypto]
PKCS11Module=$OKULAR_PKCS11_LIB
KDEPKCS11
    ok "Okular: kdeglobals PKCS#11 configured"
fi

# ── Chromium/Chrome/Brave/Electron apps ─────────────────────────────────────
# Use p11-kit proxy — apps that use NSS should find OpenSC via p11-kit
# If Chrome doesn't pick it up automatically, you can set:
#   NSS_USE_SHARED_DB=1 environment variable or use modutil on the system NSS db
# System-wide NSS db for Chrome/Chromium:
if [[ -d /etc/pki/nssdb ]] && [[ -n "$OPENSCLIB" ]]; then
    if ! modutil -dbdir sql:/etc/pki/nssdb -list 2>/dev/null | grep -q "OpenSC"; then
        sudo modutil -dbdir sql:/etc/pki/nssdb -add "OpenSC" \
            -libfile "$OPENSCLIB" -mechanisms FRIENDLY 2>/dev/null \
            && ok "System NSS: OpenSC registered" \
            || warn "System NSS: modutil failed"
    fi
fi

# ── Import DoD root certificates ─────────────────────────────────────────────
CAC_CERTS_DIR="$HOME/.local/share/niello/cac/certs"
CAC_SYSTEM_DB="/etc/pki/nssdb"
if [[ -d "$CAC_CERTS_DIR" ]] && [[ -n "$(ls -A "$CAC_CERTS_DIR" 2>/dev/null)" ]]; then
    log "importing DoD/Federal CA certificates..."
    for cert_file in "$CAC_CERTS_DIR"/*.p7b "$CAC_CERTS_DIR"/*.pem "$CAC_CERTS_DIR"/*.crt; do
        [[ -f "$cert_file" ]] || continue
        cert_name=$(basename "$cert_file")

        # Import into system NSS db (Chrome/Chromium/Brave)
        if [[ -d "$CAC_SYSTEM_DB" ]] && [[ -n "$OPENSCLIB" ]]; then
            if certutil -d sql:"$CAC_SYSTEM_DB" -A -n "$cert_name" \
                -t "C,C,C" -i "$cert_file" 2>/dev/null; then
                ok "DoD cert imported: $cert_name → system NSS"
            else
                warn "system NSS import failed: $cert_name"
            fi
        fi

        # Import into each Firefox profile
        for profile in "$HOME"/.mozilla/firefox/*.default*; do
            [[ -d "$profile" ]] || continue
            if certutil -d sql:"$profile" -A -n "$cert_name" \
                -t "C,C,C" -i "$cert_file" 2>/dev/null; then
                ok "DoD cert imported: $cert_name → $(basename "$profile")"
            else
                warn "cert import failed: $cert_name → $(basename "$profile")"
            fi
        done
    done
    ok "DoD certificate import done"
else
    log "no bundled DoD certs found — skipping (manually import via about:preferences if needed)"
fi

# ── Verify card is readable ──────────────────────────────────────────────────
if command -v pkcs15-tool &>/dev/null; then
    sleep 1
    CERTS=$(pkcs15-tool --list-certificates 2>/dev/null | grep -c "X.509 Certificate" || echo "0")
    if [[ "$CERTS" -gt 0 ]]; then
        ok "card readable — $CERTS certificate(s) found"
    else
        warn "no certs found — is the CAC card inserted? (try re-seating)"
    fi
fi

ok "CAC setup complete"