#!/usr/bin/env bash
# niello-init — Niello bootstrap, sync, and health-check
#
# Runs on every login via systemd user service (niello-init.service).
# Performs: skel sync, binary install/restore, config copy, cleanup, service start.
#
# Usage: ~/.local/bin/niello-init (called by systemd service)
#
# To force full re-sync: rm ~/.local/share/niello/.sync-done

set -eo pipefail

NIELLO_STATE_DIR="$HOME/.local/share/niello"
NIELLO_INSTALL_MARKER="$NIELLO_STATE_DIR/.installed"
NIELLO_LOG_DIR="$NIELLO_STATE_DIR"
NIELLO_LOG="$NIELLO_LOG_DIR/init.log"
SYNC_MARKER="$NIELLO_STATE_DIR/.sync-done"
SYNC_INTERVAL=3600  # Skip if synced within 1 hour
VERSION_FILE="$NIELLO_STATE_DIR/.versions"
LOCK_FILE="$NIELLO_STATE_DIR/.init-lock"

export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$UID}"
export DISPLAY="${DISPLAY:-:0}"
export WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-wayland-0}"

# Ensure Homebrew is in PATH for this session
if [[ -d "$HOME/.homebrew/bin" ]]; then
    export PATH="$HOME/.homebrew/bin:$PATH"
fi
if [[ -d "/home/linuxbrew/.linuxbrew/bin" ]]; then
    export PATH="/home/linuxbrew/.linuxbrew/bin:$PATH"
fi

mkdir -p "$NIELLO_STATE_DIR" "$NIELLO_LOG_DIR" "$HOME/.local/bin"
mkdir -p /usr/local/bin 2>/dev/null || true

# ── Logging helpers ───────────────────────────────────────────────────────────
log()  { echo "➜  $1"; }
ok()   { echo "✔  $1"; }
warn() { echo "!  $1"; }

# ── First-run tracking helpers ────────────────────────────────────────────────
is_installed() {
    local item="$1"
    [[ -f "$NIELLO_INSTALL_MARKER" ]] && grep -qxF "$item" "$NIELLO_INSTALL_MARKER" 2>/dev/null
}

mark_installed() {
    local item="$1"
    mkdir -p "$NIELLO_STATE_DIR"
    if is_installed "$item"; then
        return 0
    fi
    echo "$item" >> "$NIELLO_INSTALL_MARKER"
}

# ── Force flag: re-run full install ───────────────────────────────────────────
FORCE_INSTALL=false
if [[ "${1:-}" == "--force" ]]; then
    FORCE_INSTALL=true
fi

get_version() {
    grep "^${1}=" "$VERSION_FILE" 2>/dev/null | cut -d= -f2 || echo ""
}
set_version() {
    touch "$VERSION_FILE"
    if grep -q "^${1}=" "$VERSION_FILE" 2>/dev/null; then
        sed -i "s|^${1}=.*|${1}=${2}|" "$VERSION_FILE"
    else
        echo "${1}=${2}" >> "$VERSION_FILE"
    fi
}

# ── GUI helpers ──────────────────────────────────────────────────────────────
require_zenity() { command -v zenity &>/dev/null; }

show_error() {
    local title="$1"; local msg="$2"
    if command -v notify-send &>/dev/null; then
        notify-send -u critical -a Niello -c device "$title" "$msg" 2>/dev/null || true
    fi
    if require_zenity; then
        zenity --error --title="$title" --text="$msg" --no-wrap --width=400 2>/dev/null || true
    fi
}

# ── Sync skel file to user home ───────────────────────────────────────────────
# Copies from /etc/skel to ~ if missing or different. Always logs.
# Does NOT fail script if src is missing.
sync_skel() {
    local src="/etc/skel/$1"; local dest="$HOME/$1"
    mkdir -p "$(dirname "$dest")"
    if [[ ! -f "$src" ]]; then
        warn "skel: $src not found — skipping"
        return 0
    fi
    if [[ ! -f "$dest" ]]; then
        cp "$src" "$dest" && ok "skel: $1 copied" || warn "skel: failed to copy $1"
    elif ! cmp -s "$src" "$dest"; then
        cp "$src" "$dest" && ok "skel: $1 updated" || warn "skel: failed to update $1"
    else
        ok "skel: $1 (current)"
    fi
    return 0
}

# ── Homebrew helpers ─────────────────────────────────────────────────────────
require_brew() { command -v brew &>/dev/null; }

brew_ensure() {
    local pkg="$1"; local flag="${2:-}"
    if [[ "$flag" == "--cask" ]]; then
        brew list --cask "$pkg" &>/dev/null 2>&1 \
            && ok "brew cask: $pkg (present)" \
            || { log "brew cask: installing $pkg...";
                 brew install --cask "$pkg" 2>/dev/null \
                     && ok "brew cask: $pkg installed" \
                     || warn "brew cask: $pkg failed"; }
    else
        brew list --formula "$pkg" &>/dev/null 2>&1 \
            && ok "brew: $pkg (present)" \
            || { log "brew: installing $pkg...";
                 brew install "$pkg" 2>/dev/null \
                     && ok "brew: $pkg installed" \
                     || warn "brew: $pkg failed"; }
    fi
}

# ── Binary installer ─────────────────────────────────────────────────────────
install_binary() {
    local name="$1"; local url="$2"; local dest="$3"; local mode="${4:-755}"
    if [[ -x "$dest" ]]; then
        ok "$name: present at $dest"
        return 0
    fi
    log "$name: installing from $url..."
    local tmp
    tmp=$(mktemp)
    if curl -fsSL "$url" -o "$tmp" 2>/dev/null; then
        local dest_dir; dest_dir=$(dirname "$dest"); mkdir -p "$dest_dir"
        install -m "$mode" "$tmp" "$dest" 2>/dev/null \
            && { rm -f "$tmp"; ok "$name: installed to $dest"; return 0; } \
            || { rm -f "$tmp"; warn "$name: install to $dest failed"; return 1; }
    else
        rm -f "$tmp"; warn "$name: download from $url failed"; return 1
    fi
}

# ── Main ─────────────────────────────────────────────────────────────────────
main() {
    # Non-blocking: if another niello-init is running, exit immediately
    if [[ -f "$LOCK_FILE" ]]; then
        local LOCK_PID
        LOCK_PID=$(cat "$LOCK_FILE" 2>/dev/null || echo "")
        if [[ -n "$LOCK_PID" ]] && kill -0 "$LOCK_PID" 2>/dev/null; then
            echo "niello-init already running (pid $LOCK_PID) — skipping"
            return 0
        fi
        rm -f "$LOCK_FILE"
    fi
    echo $$ > "$LOCK_FILE"

    # ── Skip if synced recently ────────────────────────────────────────────────
    if [[ -f "$SYNC_MARKER" ]] && [[ "$FORCE_INSTALL" != "true" ]]; then
        local last_sync age
        last_sync=$(get_version "last_sync" || echo "0")
        age=$(( $(date +%s) - last_sync ))
        if [[ "$age" -lt "$SYNC_INTERVAL" ]]; then
            echo "billet-init: skipping — synced ${age}s ago (interval=${SYNC_INTERVAL}s)"
            rm -f "$LOCK_FILE"
            return 0
        fi
    fi

    # Remove strict error-exit for the background run so one failure doesn't kill everything
    set +e

    exec >> "$NIELLO_LOG" 2>&1
    echo ""
    echo "════════════════════════════════════════"
    echo "[niello-init] $(date '+%Y-%m-%d %H:%M:%S')"
    echo "════════════════════════════════════════"

    log "niello-init: starting (pid $$)"
    log "DISPLAY=$DISPLAY WAYLAND_DISPLAY=$WAYLAND_DISPLAY"

    local errors=0

    # ── Always: set up dirs and cleanup deprecated items ─────────────────────
    mkdir -p "$HOME/.config/systemd/user" "$HOME/.local/bin" "$HOME/.config/autostart"
    mkdir -p "$HOME/.local/share/applications"
    systemctl --user daemon-reload 2>/dev/null || true
    systemctl --user reset-failed 2>/dev/null || true

    # Cleanup: old noctalia-gtk service (deprecated)
    if systemctl --user is-enabled noctalia-gtk 2>/dev/null; then
        systemctl --user disable --now noctalia-gtk 2>/dev/null || true
        warn "Cleanup: old noctalia-gtk service disabled"
    fi
    rm -f "$HOME/.config/systemd/user/noctalia-gtk.service"
    rm -f "$HOME/.config/systemd/user/noctalia-gtk.service.bak"

    # Cleanup: stray Noctalia colors at root level
    rm -f "$HOME/.config/noctalia/purple-haze.json"
    rm -f "$HOME/.config/noctalia/midnight-cherry.json"
    rm -f "$HOME/.config/noctalia/eldritch.json"

    # Cleanup: old AkTags desktop files from old install paths
    rm -f "$HOME/.config/autostart/aktags.desktop.bak"

    # Cleanup: temp files from this user's state dir
    rm -rf "$NIELLO_STATE_DIR/tmp" 2>/dev/null || true

    # ── Always: sync niello-init systemd service ─────────────────────────────
    sync_skel ".config/systemd/user/niello-init.service"
    if [[ -f /etc/skel/.config/systemd/user/niello-init.service ]] && \
       [[ ! -f "$HOME/.config/systemd/user/niello-init.service" ]]; then
        cp /etc/skel/.config/systemd/user/niello-init.service \
           "$HOME/.config/systemd/user/niello-init.service" \
           && ok "niello-init.service: copied to user dir" \
           || warn "niello-init.service: failed to copy"
    fi
    if ! systemctl --user is-enabled niello-init 2>/dev/null; then
        systemctl --user enable niello-init 2>/dev/null \
            && ok "niello-init.service: enabled" \
            || warn "niello-init.service: enable failed"
    fi

    # ── Always: sync + enable GNOME keyring ─────────────────────────────────
    sync_skel ".config/systemd/user/niello-keyring.service"
    if ! systemctl --user is-enabled niello-keyring 2>/dev/null; then
        systemctl --user enable niello-keyring 2>/dev/null \
            && ok "niello-keyring.service: enabled" \
            || warn "niello-keyring.service: enable failed"
    fi

    # ── Always: show GUI status box on sync (if zenity available) ───────────
    local ZENITY_PID=""
    if require_zenity; then
        zenity --info --title="Niello Setup" --text="Syncing Niello...\n\nThis window will close when complete." --no-wrap --width=400 &
        ZENITY_PID=$!
        disown $ZENITY_PID 2>/dev/null || true
    fi

# ── 2. GTK themes (Eldritch) ─────────────────────────────────────────────
    log "--- GTK themes (Eldritch) ---"
    sync_skel ".config/gtk-3.0/settings.ini"
    sync_skel ".config/gtk-4.0/settings.ini"

    # ── 3. Niri config ─────────────────────────────────────────────────────
    # Niri config is synced from skel so users get the latest layout/keybinds
    sync_skel ".config/niri/config.kdl"
    sync_skel ".config/niri/noctalia.kdl"

    # ── 4. Homebrew packages ────────────────────────────────────────────────
    log "--- Homebrew ---"
    if ! require_brew; then
        warn "Homebrew not found — skipping brew packages"
    else
        # ALWAYS run brew update && brew upgrade to get latest packages
        log "--- Homebrew (updating) ---"
        brew update 2>/dev/null && brew upgrade 2>/dev/null || true
        ok "Homebrew: up to date"

        # ONLY install missing packages on first run (when not yet marked installed)
        if ! is_installed "homebrew-packages"; then
            log "--- Homebrew (first run - installing missing packages) ---"
            brew tap Akinus21/homebrew-tap 2>/dev/null || warn "brew: tap Akinus21/homebrew-tap failed"
            for pkg in lazygit git-delta gh gitleaks; do brew_ensure "$pkg"; done
            for pkg in atuin tmux tldr; do brew_ensure "$pkg"; done
            for pkg in jq yq xh; do brew_ensure "$pkg"; done
            for pkg in trivy grype; do brew_ensure "$pkg"; done
            for pkg in yazi duf dust age; do brew_ensure "$pkg"; done
            brew_ensure "corten"
            brew_ensure "bitwarden-cli"
            brew_ensure "iron"
            # ── Iron browser .desktop ─────────────────────────────────────────────
            log "--- Iron browser desktop ---"
            local IRON_BIN=""
            for p in "$HOME/.homebrew/bin/iron" "$HOME/.linuxbrew/bin/iron" "/home/linuxbrew/.linuxbrew/bin/iron" "/usr/local/bin/iron"; do
                [[ -x "$p" ]] && { IRON_BIN="$p"; break; }
            done
            # Fallback to PATH if direct paths not found
            if [[ -z "$IRON_BIN" ]] && command -v iron >/dev/null 2>&1; then
                IRON_BIN="$(command -v iron)"
            fi
            local IRON_DESKTOP="$HOME/.local/share/applications/iron.desktop"
            if [[ -n "$IRON_BIN" ]]; then
                if [[ ! -f "$IRON_DESKTOP" ]]; then
                    log "Iron: creating desktop entry..."
                    mkdir -p "$(dirname "$IRON_DESKTOP")"
                    cat > "$IRON_DESKTOP" << 'IRONEOF'
[Desktop Entry]
Name=Iron
Comment=Chromium-based browser
Exec=iron %U
Icon=iron
Terminal=false
Type=Application
Categories=Network;WebBrowser;
MimeType=text/html;application/xhtml+xml;x-scheme-handler(http);x-scheme-handler(https);
IRONEOF
                    ok "Iron: desktop entry created"
                    command -v update-desktop-database >/dev/null 2>&1 && \
                        update-desktop-database "$HOME/.local/share/applications" 2>/dev/null || true
                else
                    ok "Iron: desktop entry present"
                fi
            else
                warn "Iron: binary not found — check brew install"
            fi
            brew_ensure "font-meslo-lg-nerd-font" --cask
            brew_ensure "aktools"

            # ── AKTools modules ───────────────────────────────────────────────────
            log "--- AKTools modules ---"
            if command -v aktools >/dev/null 2>&1; then
                log "AKTools: upgrading..."
                aktools upgrade 2>/dev/null && ok "AKTools: upgraded" || warn "AKTools: upgrade failed"

                log "AKTools: installing niello module..."
                aktools install-mod niello 2>/dev/null && ok "AKTools: niello module installed" || warn "AKTools: niello module failed"

                log "AKTools: installing noctalia module..."
                aktools install-mod noctalia 2>/dev/null && ok "AKTools: noctalia module installed" || warn "AKTools: noctalia module failed"
            else
                warn "AKTools: not found after brew — skipping module install"
            fi
            brew_ensure "niello-session-manager"
            brew_ensure "akspraypaint"
            mark_installed "homebrew-packages"
        else
            ok "Homebrew: packages already installed (use --force to reinstall)"
        fi
    fi

    # ── Bluefin CLI tools ───────────────────────────────────────────────────
    log "--- Bluefin CLI ---"
    if command -v ujust >/dev/null 2>&1; then
        log "Running ujust bluefin-cli..."
        ujust bluefin-cli 2>&1 | tail -20 >> "$NIELLO_LOG" && \
            ok "Bluefin CLI: ujust bluefin-cli completed" || \
            warn "Bluefin CLI: ujust bluefin-cli failed"
    else
        warn "Bluefin CLI: ujust not found — skipping bluefin-cli"
    fi

    # ── Ensure Noctalia is reachable ────────────────────────────────────────
    log "--- Noctalia shell ---"
    if ! command -v qs &>/dev/null; then
        warn "Noctalia: qs not in PATH — checking /usr/bin and /usr/local/bin"
        if [[ -f /usr/bin/qs ]]; then
            ok "Noctalia: qs found at /usr/bin/qs"
        elif [[ -f /usr/local/bin/qs ]]; then
            ok "Noctalia: qs found at /usr/local/bin/qs"
        elif require_brew; then
            brew_ensure "noctalia-shell" 2>/dev/null || true
        else
            warn "Noctalia: not installed — run: sudo dnf install noctalia-shell"
        fi
    else
        ok "Noctalia: present"
    fi

    # ── 5. Flatpak (Bitwarden) ──────────────────────────────────────────────
    log "--- Flatpak ---"
    flatpak remote-add --user --if-not-exists flathub \
        https://dl.flathub.org/repo/flathub.flatpakrepo 2>/dev/null \
        && ok "flathub remote present" \
        || warn "flathub remote-add failed"

    # ALWAYS run flatpak update to keep packages current
    log "--- Flatpak (updating) ---"
    flatpak update --user -y 2>/dev/null || true
    ok "Flatpak: up to date"

    # ONLY install missing flatpaks on first run (when not yet marked installed)
    if ! is_installed "flatpak-packages"; then
        log "--- Flatpak (first run - installing missing packages) ---"
        if ! flatpak list --user --app 2>/dev/null | grep -q "com.bitwarden.desktop"; then
            log "Installing Bitwarden..."
            flatpak install --user -y flathub com.bitwarden.desktop 2>&1 \
                && ok "Bitwarden installed" \
                || warn "Bitwarden install failed"
        else
            ok "Bitwarden present"
        fi

        # ── OnlyOffice Desktop Editors ─────────────────────────────────────────
        if ! flatpak list --user --app 2>/dev/null | grep -q "org.onlyoffice.desktopeditors"; then
            log "Installing OnlyOffice..."
            flatpak install --user -y flathub org.onlyoffice.desktopeditors 2>&1 \
                && ok "OnlyOffice installed" \
                || warn "OnlyOffice install failed"
        else
            ok "OnlyOffice present"
        fi

        # ── Gaming flatpaks ────────────────────────────────────────────────────
        if [[ -f /etc/niello-gaming ]]; then
            GAMING_FLATPAKS=(
                "com.valvesoftware.Steam"
                "com.github.Matoking.protontricks"
                "net.davidotek.pupgui2"
                "com.heroicgameslauncher.hgl"
            )
            for fp in "${GAMING_FLATPAKS[@]}"; do
                if ! flatpak list --user --app 2>/dev/null | grep -q "$fp"; then
                    log "Gaming: installing $fp..."
                    flatpak install --user -y flathub "$fp" 2>&1 \
                        && ok "Gaming: $fp installed" \
                        || warn "Gaming: $fp install failed"
                else
                    ok "Gaming: $fp (present)"
                fi
            done
        fi
        mark_installed "flatpak-packages"
    else
        ok "Flatpak: packages already installed (use --force to reinstall)"
    fi

    # ── Bitwarden CLI (bw) ──────────────────────────────────────────────────
    log "--- Bitwarden CLI (bw) ---"
    if ! command -v bw &>/dev/null; then
        warn "bw: not found — install with: brew install bitwarden-cli"
    else
        ok "bw: present"
    fi

    # ── Gaming (nvidia variant) ──────────────────────────────────────────────
    if [[ -f /etc/niello-gaming ]]; then
        log "--- Gaming setup ---"

        # Add user to gamemode group for performance mode
        if getent group gamemode &>/dev/null; then
            sudo usermod -aG gamemode "$USER" 2>/dev/null \
                && ok "gamemode: $USER added to group" \
                || warn "gamemode: failed to add $USER to group"
        else
            warn "gamemode: group not found"
        fi

        # Gaming flatpaks
        GAMING_FLATPAKS=(
            "com.valvesoftware.Steam"
            "com.github.Matoking.protontricks"
            "net.davidotek.pupgui2"
            "com.heroicgameslauncher.hgl"
        )
        for fp in "${GAMING_FLATPAKS[@]}"; do
            if ! flatpak list --user --app 2>/dev/null | grep -q "$fp"; then
                log "Gaming: installing $fp..."
                flatpak install --user -y flathub "$fp" 2>&1 \
                    && ok "Gaming: $fp installed" \
                    || warn "Gaming: $fp install failed"
            else
                ok "Gaming: $fp (present)"
            fi
        done
    else
        ok "Gaming: not a gaming variant — skipping"
    fi

    # ── 6. CAC setup ─────────────────────────────────────────────────────────
    log "--- CAC setup ---"
    CAC_SETUP="/etc/skel/.local/bin/cac-setup"
    if [[ -x "$CAC_SETUP" ]]; then
        bash "$CAC_SETUP" && ok "CAC setup complete" || warn "CAC setup failed"
    elif [[ -f "$CAC_SETUP" ]]; then
        chmod +x "$CAC_SETUP" && bash "$CAC_SETUP" && ok "CAC setup complete" || warn "CAC setup failed"
    else
        warn "cac-setup not found in skel — skipping"
    fi

# ── 7. Ollama ────────────────────────────────────────────────────────────
    log "--- Ollama ---"
    if is_installed "ollama" && [[ "$FORCE_INSTALL" != "true" ]]; then
        log "--- Ollama (updating) ---"
        # Just ensure it's running, no re-install
        systemctl --user enable --now ollama 2>/dev/null || true
        if pgrep -x "ollama" >/dev/null 2>&1; then
            ok "Ollama: serve already running"
        else
            mkdir -p "$HOME/.cache/ollama"
            nohup /usr/local/bin/ollama serve > "$NIELLO_LOG_DIR/ollama.log" 2>&1 &
            disown >/dev/null 2>&1 || true
            sleep 1
            if pgrep -x "ollama" >/dev/null 2>&1; then
                ok "Ollama: serve started"
            else
                warn "Ollama: background start failed"
            fi
        fi
    elif ! command -v /usr/local/bin/ollama &>/dev/null; then
        log "Ollama: installing binary..."
        OLLAMA_VER=$(curl -fsSL https://api.github.com/repos/ollama/ollama/releases/latest 2>/dev/null \
            | grep '"tag_name"' | cut -d'"' -f4 || echo "latest")
        if curl -fsSL "https://github.com/ollama/ollama/releases/download/${OLLAMA_VER}/ollama-linux-amd64" \
               -o /tmp/ollama && chmod +x /tmp/ollama; then
            sudo mv /tmp/ollama /usr/local/bin/ollama \
                && ok "Ollama: binary installed" \
                || warn "Ollama: binary install failed"
        else
            warn "Ollama: download failed"
        fi
        mark_installed "ollama"
    else
        ok "Ollama: binary present"
        mark_installed "ollama"
    fi
    sync_skel ".config/systemd/user/ollama.service"
    if ! systemctl --user enable --now ollama 2>/dev/null; then
        warn "Ollama: failed to start via systemd"
    else
        ok "Ollama: enabled"
    fi
    # Start ollama serve in background directly (faster than waiting for systemd)
    if command -v /usr/local/bin/ollama &>/dev/null; then
        if ! pgrep -x "ollama" >/dev/null 2>&1; then
            mkdir -p "$HOME/.cache/ollama"
            nohup /usr/local/bin/ollama serve > "$NIELLO_LOG_DIR/ollama.log" 2>&1 &
            disown >/dev/null 2>&1 || true
            sleep 1
            if pgrep -x "ollama" >/dev/null 2>&1; then
                ok "Ollama: serve started in background"
            else
                warn "Ollama: background start failed — check ~/.local/share/niello/ollama.log"
            fi
        else
            ok "Ollama: serve already running"
        fi
    fi

    # ── 8. Zsh config (Powerlevel10k + plugins) ────────────────────────────
    log "--- Zsh config ---"
    sync_skel ".zshrc"
    sync_skel ".p10k.zsh"
    sync_skel "justfile"

    # ── Zsh + Oh-My-Zsh validation ───────────────────────────────────────────
    log "--- Zsh + Oh-My-Zsh ---"
    if ! command -v zsh &>/dev/null; then
        if require_brew; then
            brew install zsh 2>/dev/null && ok "Zsh: installed" \
                || warn "Zsh: brew install failed"
        else
            warn "Zsh: not found and brew unavailable"
        fi
    else
        ok "Zsh: present"
    fi

    local OMZ="$HOME/.oh-my-zsh"
    local OMZ_PLUGINS="$OMZ/custom/plugins"
    local OMZ_THEMES="$OMZ/custom/themes"

    if is_installed "oh-my-zsh" && [[ "$FORCE_INSTALL" != "true" ]]; then
        log "--- OMZ (updating plugins) ---"
        # Just git pull in each plugin/theme directory
        for dir in "$OMZ_PLUGINS"/* "$OMZ_THEMES"/*; do
            [[ -d "$dir/.git" ]] && (cd "$dir" && git pull --ff-only 2>/dev/null) || true
        done
        ok "OMZ: up to date"
    else
        # Check base Oh-My-Zsh first
        if [[ ! -d "$OMZ/.git" ]]; then
            log "OMZ: base directory missing — cloning..."
            git clone --depth=1 https://github.com/ohmyzsh/ohmyzsh.git "$OMZ" 2>/dev/null \
                && ok "OMZ: oh-my-zsh installed" \
                || warn "OMZ: oh-my-zsh clone failed"
        else
            ok "OMZ: base directory present"
        fi

        mkdir -p "$OMZ_PLUGINS" "$OMZ_THEMES"

        for plugin in zsh-autosuggestions zsh-syntax-highlighting zsh-completions; do
            if [[ ! -d "$OMZ_PLUGINS/$plugin" ]]; then
                log "OMZ: cloning $plugin..."
                git clone --depth=1 "https://github.com/zsh-users/$plugin.git" \
                    "$OMZ_PLUGINS/$plugin" 2>/dev/null \
                    && ok "OMZ: $plugin installed" \
                    || warn "OMZ: $plugin clone failed"
            else
                ok "OMZ: $plugin (present)"
            fi
        done

        if [[ ! -d "$OMZ_THEMES/powerlevel10k" ]]; then
            log "OMZ: cloning powerlevel10k..."
            git clone --depth=1 "https://github.com/romkatv/powerlevel10k.git" \
                "$OMZ_THEMES/powerlevel10k" 2>/dev/null \
                && ok "OMZ: powerlevel10k installed" \
                || warn "OMZ: powerlevel10k clone failed"
        else
            ok "OMZ: powerlevel10k (present)"
        fi
        mark_installed "oh-my-zsh"
    fi

    # ── Noctalia color scheme ───────────────────────────────────────────────
    log "--- Noctalia color scheme ---"

    # Sync noctalia config dir (greeter uses greeter.toml, not CSS templates)
    sync_skel ".config/noctalia"

    # Read active theme from settings.json, default to "Purple Haze" if missing
    local ACTIVE_THEME="Purple Haze"
    local SETTINGS_JSON="$HOME/.config/noctalia/settings.json"
    if [[ -f "$SETTINGS_JSON" ]]; then
        local EXTRACTED_THEME
        EXTRACTED_THEME=$(python3 -c "import json; print(json.load(open('$SETTINGS_JSON')).get('activeColorScheme', 'Purple Haze'))" 2>/dev/null)
        if [[ -n "$EXTRACTED_THEME" ]]; then
            ACTIVE_THEME="$EXTRACTED_THEME"
        fi
    fi

    local ACTIVE_THEME_SRC="/etc/skel/.config/noctalia/colorschemes/${ACTIVE_THEME}/${ACTIVE_THEME}.json"
    local ACTIVE_THEME_DEST="$HOME/.config/noctalia/colorschemes/${ACTIVE_THEME}/${ACTIVE_THEME}.json"
    mkdir -p "$(dirname "$ACTIVE_THEME_DEST")"
    if [[ -f "$ACTIVE_THEME_SRC" ]]; then
        if [[ ! -f "$ACTIVE_THEME_DEST" ]] || ! cmp -s "$ACTIVE_THEME_SRC" "$ACTIVE_THEME_DEST"; then
            cp "$ACTIVE_THEME_SRC" "$ACTIVE_THEME_DEST" \
                && ok "Noctalia: ${ACTIVE_THEME} installed" \
                || warn "Noctalia: ${ACTIVE_THEME} install failed"
        else
            ok "Noctalia: ${ACTIVE_THEME} (current)"
        fi
    else
        warn "Noctalia: ${ACTIVE_THEME} source not in skel"
    fi

    # ── Noctalia plugin repositories ────────────────────────────────────────
    log "--- Noctalia plugin repos ---"
    local SETTINGS_FILE="$HOME/.config/noctalia/settings.json"
    if [[ -f "$SETTINGS_FILE" ]]; then
        if grep -q "pluginRepositories" "$SETTINGS_FILE" 2>/dev/null; then
            ok "Noctalia: plugin repos (present)"
        else
            log "Noctalia: adding plugin repos..."
            python3 -c "
import json, sys
with open('$SETTINGS_FILE', 'r') as f:
    data = json.load(f)
data['pluginRepositories'] = [
    'https://github.com/Akinus21/noctalia-plugins',
    'https://github.com/noctalia-dev/noctalia-plugins'
]
with open('$SETTINGS_FILE', 'w') as f:
    json.dump(data, f, indent=2)
" 2>/dev/null \
                && ok "Noctalia: plugin repos added" \
                || warn "Noctalia: plugin repos update failed"
        fi
    else
        warn "Noctalia: settings.json not found"
    fi

    # ── Noctalia wallpaper ────────────────────────────────────────────────────
    log "--- Noctalia wallpaper ---"
    local WALLPAPER_SRC="/etc/skel/.config/noctalia/noctalia_purple_haze.png"
    local WALLPAPER_DEST="$HOME/.config/noctalia/wallpapers/noctalia_purple_haze.png"
    mkdir -p "$(dirname "$WALLPAPER_DEST")"
    if [[ -f "$WALLPAPER_SRC" ]]; then
        if [[ ! -f "$WALLPAPER_DEST" ]] || ! cmp -s "$WALLPAPER_SRC" "$WALLPAPER_DEST"; then
            cp "$WALLPAPER_SRC" "$WALLPAPER_DEST" \
                && ok "Noctalia: wallpaper installed" \
                || warn "Noctalia: wallpaper install failed"
        else
            ok "Noctalia: wallpaper (current)"
        fi
    else
        warn "Noctalia: wallpaper source not in skel"
    fi

    # ── Noctalia plugins (Akinus21/noctalia-plugins) ────────────────────────
    log "--- Noctalia plugins ---"
    local PLUGINS_DIR="$HOME/.config/noctalia/plugins"
    local PLUGINS_REPO="https://github.com/Akinus21/noctalia-plugins.git"
    local DEFAULT_PLUGINS=("niri-keybinds" "linkding" "bitwarden" "akspraypaint-provider")
    mkdir -p "$PLUGINS_DIR"

    if is_installed "noctalia-plugins" && [[ "$FORCE_INSTALL" != "true" ]]; then
        log "--- Noctalia plugins (updating) ---"
        for plugin in "${DEFAULT_PLUGINS[@]}"; do
            local PLUGIN_PATH="$PLUGINS_DIR/$plugin"
            if [[ -d "$PLUGIN_PATH/.git" ]]; then
                (cd "$PLUGIN_PATH" && git pull --ff-only 2>/dev/null) || true
                ok "Noctalia plugin: $plugin (up to date)"
            else
                log "Noctalia: reinstalling plugin '$plugin'..."
                # Fallback to fresh clone if git dir missing
                PLUGIN_TMP=$(mktemp -d)
                if git clone --filter=blob:none --no-checkout --depth=1 "$PLUGINS_REPO" "$PLUGIN_TMP" 2>/dev/null; then
                    cd "$PLUGIN_TMP" && \
                        git sparse-checkout set --no-cone "$plugin" && \
                        git checkout && \
                        rm -rf "$PLUGIN_PATH" && \
                        cp -r "$PLUGIN_TMP/$plugin" "$PLUGIN_PATH" && \
                        ok "Noctalia plugin: $plugin reinstalled" || \
                        warn "Noctalia plugin: $plugin failed"
                else
                    warn "Noctalia plugin: $plugin clone failed"
                fi
                cd /
                rm -rf "$PLUGIN_TMP"
            fi
        done
    else
        for plugin in "${DEFAULT_PLUGINS[@]}"; do
            local PLUGIN_PATH="$PLUGINS_DIR/$plugin"
            local PLUGIN_TMP
            if [[ -d "$PLUGIN_PATH" ]]; then
                ok "Noctalia plugin: $plugin (present)"
            else
                log "Noctalia: installing plugin '$plugin'..."
                PLUGIN_TMP=$(mktemp -d)
                if git clone --filter=blob:none --no-checkout --depth=1 "$PLUGINS_REPO" "$PLUGIN_TMP" 2>/dev/null; then
                    cd "$PLUGIN_TMP" && \
                        git sparse-checkout set --no-cone "$plugin" && \
                        git checkout && \
                        cp -r "$PLUGIN_TMP/$plugin" "$PLUGIN_PATH" && \
                        ok "Noctalia plugin: $plugin installed" || \
                        warn "Noctalia plugin: $plugin sparse checkout failed"
                else
                    warn "Noctalia plugin: $plugin clone failed"
                fi
                cd /
                rm -rf "$PLUGIN_TMP"
            fi
        done
        mark_installed "noctalia-plugins"
    fi



    # ── Always: ensure all tracked services are running ────────────────────
    log "--- Service health ---"
    systemctl --user start ollama 2>/dev/null || true

    # ── Ensure Noctalia is running ────────────────────────────────────────
    log "--- Noctalia health check ---"
    if pgrep -x "qs" >/dev/null 2>&1 || pgrep -f "noctalia-shell" >/dev/null 2>&1; then
        ok "Noctalia: running"
    else
        log "Noctalia: not running — attempting to start..."
        if command -v qs >/dev/null 2>&1; then
            nohup qs -c noctalia-shell >/dev/null 2>&1 &
            disown >/dev/null 2>&1 || true
            sleep 1
            if pgrep -x "qs" >/dev/null 2>&1; then
                ok "Noctalia: started"
            else
                warn "Noctalia: failed to start (qs returned immediately)"
            fi
        else
            warn "Noctalia: qs binary not found — cannot auto-start"
        fi
    fi

    # Mark sync complete
    set_version "last_run" "$(date +%s)"  # Always updated, even on failure
    touch "$SYNC_MARKER"
    set_version "last_sync" "$(date +%s)"

    echo ""
    # Kill status box
    if [[ -n "$ZENITY_PID" ]] && kill -0 "$ZENITY_PID" 2>/dev/null; then
        kill "$ZENITY_PID" 2>/dev/null || true
    fi

    # Cleanup lock
    rm -f "$LOCK_FILE"

    if [[ $errors -gt 0 ]]; then
        ok "niello-init complete with $errors error(s) — see ~/.local/share/niello/init.log"
        show_error "Niello Setup" "niello-init finished with $errors error(s).\nCheck ~/.local/share/niello/init.log for details."
    else
        ok "niello-init complete"
        if command -v notify-send &>/dev/null; then
            # Give notification daemon time to be ready, use icon flag
            sleep 2
            notify-send -u normal -a Niello -i niello "Niello Ready" "System sync complete. Log: ~/.local/share/niello/init.log" 2>/dev/null || true
        fi
    fi
    log "niello-init: finished (pid $$)"
}

# If run in the foreground (e.g., from /etc/zshenv or .zshrc), spawn a
# background subshell so the terminal is never blocked.
if [[ "${NIELLO_INIT_FOREGROUND:-}" != "1" ]]; then
    (
        NIELLO_INIT_FOREGROUND=1
        "$0" > "$NIELLO_LOG" 2>&1
    ) &
    exit 0
fi

main "$@"